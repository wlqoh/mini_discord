VITE_API_URL=/api/v1
VITE_WS_URL=wss://hyorward.tech/api/v1/server/ws

# Comma-separated STUN list
VITE_WEBRTC_STUN_URLS=stun:stun.l.google.com:19302

# Comma-separated TURN/TURNS list
VITE_WEBRTC_TURN_URLS=turn:hyorward.tech:3478?transport=udp,turn:hyorward.tech:3478?transport=tcp,turns:hyorward.tech:5349?transport=tcp
VITE_WEBRTC_TURN_USERNAME=mini_discord
VITE_WEBRTC_TURN_CREDENTIAL=change-me

# For maximum cross-network compatibility, keep relay enabled in production.
VITE_WEBRTC_FORCE_RELAY=true

# docker-compose TURN service settings
TURN_REALM=hyorward.tech
TURN_PUBLIC_IP=45.155.205.212
TURN_USERNAME=mini_discord
TURN_PASSWORD=change-me-turn-password
TURN_TLS_CERT_FILE=/etc/letsencrypt/live/hyorward.tech/fullchain.pem
TURN_TLS_KEY_FILE=/etc/letsencrypt/live/hyorward.tech/privkey.pem

