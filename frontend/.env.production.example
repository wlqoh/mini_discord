VITE_API_URL=/api/v1
VITE_WS_URL=wss://hyorward.tech/api/v1/server/ws

# Comma-separated STUN list
VITE_WEBRTC_STUN_URLS=stun:stun.l.google.com:19302

# Comma-separated TURN/TURNS list
VITE_WEBRTC_TURN_URLS=turn:hyorward.tech:3478?transport=udp,turn:hyorward.tech:3478?transport=tcp

# Optional static TURN credentials (not recommended for production).
# If unset, frontend requests temporary TURN credentials from backend endpoint /api/v1/webrtc/turn-credentials.
# VITE_WEBRTC_TURN_USERNAME=
# VITE_WEBRTC_TURN_CREDENTIAL=

# Use true only for diagnostics when forcing relay via TURN
VITE_WEBRTC_FORCE_RELAY=false

# docker-compose TURN service settings
TURN_REALM=hyorward.tech
TURN_PUBLIC_IP=45.155.205.212
TURN_USERNAME=mini_discord
TURN_PASSWORD=change-me-turn-password

